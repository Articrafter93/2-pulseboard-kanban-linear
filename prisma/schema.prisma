generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum Priority {
  URGENT
  HIGH
  NORMAL
  LOW
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  DONE
}

model Organization {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  members    Member[]
  projects   Project[]
  cycles     Cycle[]
  tasks      Task[]
  activities Activity[]
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  userExternalId String
  displayName    String
  role           Role
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTasks  Task[]       @relation("TaskAssignee")

  @@index([organizationId, role])
  @@unique([organizationId, userExternalId])
}

model Project {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  key            String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks          Task[]
  cycles         Cycle[]

  @@unique([organizationId, key])
}

model Cycle {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String?
  name           String
  startsAt       DateTime
  endsAt         DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tasks          Task[]
}

model Task {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String
  cycleId        String?
  assigneeId     String?
  title          String
  description    String
  labels         String[]     @default([])
  priority       Priority
  status         TaskStatus
  dueDate        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cycle          Cycle?       @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  assignee       Member?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments       Comment[]
  activities     Activity[]

  @@index([organizationId, status, priority])
}

model Comment {
  id        String   @id @default(cuid())
  taskId     String
  body      String
  author    String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Activity {
  id             String       @id @default(cuid())
  organizationId String
  taskId          String?
  actor           String
  eventType       String
  payload         Json?
  createdAt       DateTime     @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task            Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
}
