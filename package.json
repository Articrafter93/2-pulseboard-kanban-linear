{
  "name": "2--kanban-colaborativo-estilo-linear",
  "version": "0.1.0",
  "private": true,
  "description": "Pulseboard MVP - collaborative work management platform",
  "scripts": {
    "dev": "next dev",
    "realtime:dev": "npm --prefix realtime-service run dev",
    "build": "node scripts/prisma-generate-safe.mjs && next build",
    "start": "next start",
    "realtime:build": "npm --prefix realtime-service run build",
    "realtime:start": "npm --prefix realtime-service run start",
    "lint": "next lint",
    "e2e:prepare": "npm run prisma:push && npm run prisma:seed && npm run build && npm run realtime:build",
    "e2e:serve": "concurrently -k -s first \"npm run start\" \"npm run realtime:start\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prisma:generate": "prisma generate",
    "prisma:push": "node scripts/with-env.mjs prisma db push",
    "prisma:seed": "node scripts/with-env.mjs tsx prisma/seed.ts",
    "lighthouse:prod": "node scripts/run-lighthouse.mjs"
  },
  "keywords": [
    "nextjs",
    "kanban",
    "saas",
    "pulseboard"
  ],
  "author": "",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.16.2",
    "@tanstack/react-virtual": "^3.13.22",
    "dotenv": "^16.6.1",
    "ioredis": "^5.10.0",
    "next": "^15.5.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io-client": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.12",
    "lighthouse": "^12.8.2",
    "postcss": "^8.5.8",
    "prisma": "^6.16.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
